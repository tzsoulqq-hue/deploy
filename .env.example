# Host ports.
WEBUI_PORT=8080
GOPAY_WEBHOOK_PORT=8081
POSTGRES_PORT=5432
WORKFLOW_RUNTIME_PORT=7233
BROWSER_AUTOMATION_GRPC_PORT=50062
MAILBOX_GRPC_PORT=50058
MAILBOX_WEBHOOK_PORT=8082
GPT_ACCOUNT_GRPC_PORT=50052
GPT_PAYMENT_GRPC_PORT=50054
GPT_SERVICE_GRPC_PORT=50055
SMS_SERVICE_GRPC_PORT=50061

# Core storage and workflow runtime.
POSTGRES_USER=byte_v_forge
POSTGRES_PASSWORD=byte_v_forge
POSTGRES_DB=byte_v_forge
WORKFLOW_RUNTIME_NAMESPACE=default
GPT_WORKFLOW_RUNTIME_TASK_QUEUE=byte-v-forge-gpt-service
MAILBOX_WORKFLOW_RUNTIME_TASK_QUEUE=byte-v-forge-mailbox-service

# Browser automation.
BROWSER_AUTOMATION_APPLY_MIGRATIONS=true
BROWSER_AUTOMATION_RUNTIME=camoufox
BROWSER_AUTOMATION_PROXY_REFS_JSON={"register":"socks5://host.docker.internal:10813","outlook":"socks5://host.docker.internal:10810"}
CAMOUFOX_FETCH_PROXY=http://host.docker.internal:10809

# Mailbox inbound email webhook.
MAILBOX_WEBHOOK_TOKEN=
MAILBOX_CLOUDFLARE_API_TOKEN=
MAILBOX_CLOUDFLARE_MAX_MESSAGES_PER_DOMAIN=500
MAILBOX_OUTLOOK_MAX_MESSAGES_PER_MAILBOX=100
GPT_MAILBOX_WEBHOOK_TOKEN=

# GoPay proxy refs.
GOPAY_DYNAMIC_EGRESS=socks5://proxy-runtime:10811
GOPAY_CHECKOUT_PROXY_URL=socks5://proxy-runtime:10812
GOPAY_PAYMENT_PROXY_URL=socks5://proxy-runtime:10810
PROXY_RUNTIME_HTTP_ADDR=http://proxy-runtime:8080
GOPAY_SIGNUP_INITIATE_JITTER_MIN_SECONDS=8
GOPAY_SIGNUP_INITIATE_JITTER_MAX_SECONDS=25
GOPAY_SIGNUP_RATE_LIMIT_COOLDOWN_SECONDS=900
GOTO_SSO_CLIENT_SECRET=

# Manual add-balance mode.
GOPAY_ADD_BALANCE_ENVELOPE_LINK=
GOPAY_ADD_BALANCE_TRANSFER_INSTRUCTIONS=
