services {
  name: "gpt"
  kind: DASHBOARD_SERVICE_PROBE_TCP
  target: "gpt-service:50051"
  timeout_ms: 1500
}
services {
  name: "mailbox"
  kind: DASHBOARD_SERVICE_PROBE_TCP
  target: "mailbox:50051"
  timeout_ms: 1500
}
services {
  name: "sms"
  kind: DASHBOARD_SERVICE_PROBE_TCP
  target: "sms-service:50051"
  timeout_ms: 1500
}
services {
  name: "workflow-runtime"
  kind: DASHBOARD_SERVICE_PROBE_HTTP
  target: "http://workflow-runtime:8080/healthz"
  timeout_ms: 1500
}
